# Copy this file to .env and fill in real values. Never commit .env.

# MongoDB connection string (required). Get one from MongoDB Atlas (cloud)
# or run a local MongoDB instance. See docs/SETUP.md for instructions.
MONGODB_URI=mongodb://localhost:27017/auraava

# Port the Express server listens on
PORT=5000

# The frontend's origin, used for CORS. Must match exactly (no trailing slash).
FRONTEND_URL=http://localhost:3000

# Secret used to sign/verify admin JWTs. Required — the server will refuse to
# start without it. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be IDENTICAL to the JWT_SECRET used in frontend/.env.local.
JWT_SECRET=

# Admin login credentials (required). Change these from any defaults.
ADMIN_USERNAME=
ADMIN_PASSWORD=

NODE_ENV=development

# Razorpay API keys (optional). Get these from the Razorpay Dashboard >
# Settings > API Keys. If left blank, Direct Checkout still works end-to-end
# (orders are created with paymentStatus: pending) but online payment is
# disabled with a friendly message shown to the customer instead of a crash.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Razorpay webhook secret (optional; Dashboard > Settings > Webhooks > your
# webhook > Secret). Used to verify the X-Razorpay-Signature header on
# incoming webhook events. If left blank, the webhook endpoint rejects all
# events rather than trusting unverified payloads.
RAZORPAY_WEBHOOK_SECRET=
