# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Base URL of the backend API, WITHOUT a trailing /api — next.config.js's
# rewrite rule appends /api/:path* itself. e.g. https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:5000

# Public site URL, used for SEO metadata, sitemap.xml, and robots.txt
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Must be IDENTICAL to JWT_SECRET in backend/.env — used by middleware.ts to
# verify the admin session cookie without a network round-trip.
JWT_SECRET=
